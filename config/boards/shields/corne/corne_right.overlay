&pro_micro_i2c{
    status = "okay" ;

    oled: ssd1306@3c{
        compatible = "sinowealth,sh1106";
        reg=<0x3c>;
        width = <128>;
        height = <32>;
        segment-offset=<0>;
        page-offset=<0>;
        display-offset=<0>;
        multiplex-ratio=<31>;
        prechargep = <0x22>;
        segment-rmap;
        com-invdir;
        com-sequential;
    }
}